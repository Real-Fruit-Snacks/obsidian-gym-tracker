{
	"name": "obsidian-gym-tracker",
	"version": "1.0.5",
	"description": "Track gym workouts from Obsidian on mobile and desktop.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "vitest run"
	},
	"keywords": [
		"obsidian",
		"gym",
		"workout",
		"fitness"
	],
	"author": "Real-Fruit-Snacks",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Real-Fruit-Snacks/obsidian-gym-tracker.git"
	},
	"bugs": {
		"url": "https://github.com/Real-Fruit-Snacks/obsidian-gym-tracker/issues"
	},
	"homepage": "https://real-fruit-snacks.github.io/obsidian-gym-tracker/",
	"devDependencies": {
		"@types/node": "^24.0.0",
		"esbuild": "^0.25.0",
		"obsidian": "1.13.1",
		"typescript": "^5.8.0",
		"vitest": "^3.0.0"
	}
}
